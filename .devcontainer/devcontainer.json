// Adopting the default GitHub codespaces-jupyter template as starter
// https://github.com/github/codespaces-jupyter
{
  "name": "Generative AI For Beginners",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "hostRequirements": { "cpus": 4 },

  // Wait for the dependency install to finish before VS Code attaches
  "waitFor": "updateContentCommand",

  // Upgrade build tooling first, then install deps
  "updateContentCommand": "python3 -m pip install -U pip setuptools wheel && python3 -m pip install -r requirements.txt",

  // Keep your post-create script
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "customizations": {
    "codespaces": { "openFiles": [] },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  }
}

